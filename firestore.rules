rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: posts
    // Fields: title (string), content (string), image (url), category (enum), views (int), createdAt (timestamp), productLink (url, optional)
    //
    // Collection: settings
    // Fields: instagram, facebook, pinterest, youtube (urls), editorName, editorBio, profileImage, websiteLogo, footerText
    //
    // Collection: analytics
    // Fields: pageViews (int), clicks (int), dailyStats (map)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          request.auth.token.email == "anassdeeqe@gmail.com" ||
          request.auth.token.email == "salmabibi7867868@gmail.com");
    }

    function isValidUrl(url) {
      return url is string && (url == "" || url.matches("^https://.*") || url.matches("^http://.*") || url.matches("^data:image/.*"));
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // Domain Validators
    function isValidPost(data) {
      return hasOnlyAllowedFields(['title', 'content', 'image', 'category', 'views', 'createdAt', 'productLink']) &&
             data.title is string && data.title.size() >= 5 && data.title.size() <= 100 &&
             data.content is string && data.content.size() >= 10 && data.content.size() <= 10000 &&
             isValidUrl(data.image) &&
             data.category in ['Summer', 'Wedding', 'Jewelry', 'Trending'] &&
             data.views is number && data.views >= 0 &&
             (!('productLink' in data) || isValidUrl(data.productLink));
    }

    function isValidSettings(data) {
      return hasOnlyAllowedFields(['instagram', 'facebook', 'pinterest', 'youtube', 'editorName', 'editorBio', 'profileImage', 'websiteLogo', 'footerText', 'contact']) &&
             (!('instagram' in data) || isValidUrl(data.instagram)) && 
             (!('facebook' in data) || isValidUrl(data.facebook)) &&
             (!('pinterest' in data) || isValidUrl(data.pinterest)) &&
             (!('youtube' in data) || isValidUrl(data.youtube)) &&
             (!('profileImage' in data) || isValidUrl(data.profileImage)) &&
             (!('websiteLogo' in data) || isValidUrl(data.websiteLogo)) &&
             (!('editorName' in data) || (data.editorName is string && data.editorName.size() <= 50));
    }

    // Rules
    match /_test_/{docId} {
      allow read: if true;
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if isAdmin() && isValidPost(request.resource.data);
      allow update: if (isAdmin() && isValidPost(request.resource.data)) || 
                     (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']) && 
                      request.resource.data.views == resource.data.views + 1);
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow create: if (settingId == 'main' && !exists(/databases/$(database)/documents/settings/main)) || isAdmin();
      allow update: if isAdmin() && isValidSettings(request.resource.data);
      allow delete: if isAdmin();
    }

    match /analytics/{analyticsId} {
      allow read: if true;
      allow create: if (analyticsId == 'main' && !exists(/databases/$(database)/documents/analytics/main)) || isAdmin();
      allow update: if (isAdmin()) || 
                     (request.resource.data.diff(resource.data).affectedKeys().hasAny(['pageViews']) &&
                      (request.resource.data.pageViews == resource.data.pageViews + 1));
    }
  }
}
